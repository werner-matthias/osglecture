
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeTUChemnitzTalk}[2026-06-16 TU Chemnitz Beamer theme]
\RequirePackage{xcolor,graphicx,kvoptions}
\SetupKeyvalOptions{family=tuc,prefix=tuc@}
\DeclareStringOption[haus]{faculty}
\DeclareStringOption[www.tu-chemnitz.de]{url}
\DeclareStringOption[]{logo}
\ProcessKeyvalOptions*
\definecolor{TUCHaus}{HTML}{005F50}
\definecolor{TUCNaturwissenschaften}{HTML}{70706F}
\definecolor{TUCMathematik}{HTML}{A10B70}
\definecolor{TUCMaschinenbau}{HTML}{123375}
\definecolor{TUCETIT}{HTML}{E4032D}
\definecolor{TUCInformatik}{HTML}{4A8246}
\definecolor{TUCWirtschaft}{HTML}{9D0736}
\definecolor{TUCPhilosophie}{HTML}{C65306}
\definecolor{TUCHSW}{HTML}{0075BF}
\makeatletter
\newcommand\tuc@color{TUCHaus}
\newcommand\tuc@selectfaculty[1]{\def\tuc@tmp{#1}\def\x{naturwissenschaften}\ifx\tuc@tmp\x\renewcommand\tuc@color{TUCNaturwissenschaften}\fi\def\x{mathematik}\ifx\tuc@tmp\x\renewcommand\tuc@color{TUCMathematik}\fi\def\x{maschinenbau}\ifx\tuc@tmp\x\renewcommand\tuc@color{TUCMaschinenbau}\fi\def\x{etit}\ifx\tuc@tmp\x\renewcommand\tuc@color{TUCETIT}\fi\def\x{informatik}\ifx\tuc@tmp\x\renewcommand\tuc@color{TUCInformatik}\fi\def\x{wirtschaft}\ifx\tuc@tmp\x\renewcommand\tuc@color{TUCWirtschaft}\fi\def\x{philosophie}\ifx\tuc@tmp\x\renewcommand\tuc@color{TUCPhilosophie}\fi\def\x{hsw}\ifx\tuc@tmp\x\renewcommand\tuc@color{TUCHSW}\fi}
\tuc@selectfaculty{\tuc@faculty}
\newcommand\tucsetlogo[1]{\renewcommand\tuc@logo{#1}}
\newcommand\tucfaculty[1]{\tuc@selectfaculty{#1}}
\setbeamercolor{normal text}{fg=black,bg=white}
\setbeamercolor{structure}{fg=\tuc@color}
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{headline}{%
  \leavevmode\noindent\begingroup\setlength\fboxsep{0pt}%
  \colorbox{\tuc@color}{\makebox[\paperwidth][l]{\hspace{7mm}\color{white}\sffamily\bfseries\strut\insertframetitle}}%
  \endgroup}
\setbeamertemplate{footline}{\leavevmode\hbox to\paperwidth{\hspace{7mm}\tiny\insertshortauthor\hfill\tuc@url\hfill\insertframenumber\hspace{7mm}}\vspace{1mm}}
\setbeamertemplate{title page}{%
  \vbox{}\vskip-6mm\noindent\begingroup\setlength\fboxsep{0pt}%
  \colorbox{\tuc@color}{\makebox[\paperwidth][l]{\hspace{7mm}\ifx\tuc@logo\@empty\else\includegraphics[width=30mm]{\tuc@logo}\fi\hspace{7mm}{\color{white}\Large\bfseries\inserttitle}}}%
  \endgroup\vfill\insertauthor\par\insertinstitute\par\insertdate\par\vfill}
\makeatother
