
% tuc-ltx-talk.sty --- TU Chemnitz theme for ltx-talk using L3 templates
\NeedsTeXFormat{LaTeX2e}[2022-06-01]
\ProvidesExplPackage{tuc-ltx-talk}{2026-06-16}{0.3.2}{TU Chemnitz ltx-talk L3 template theme}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{l3keys2e}
\RequirePackage{xtemplate}

\definecolor{TUCHaus}{HTML}{005F50}
\definecolor{TUCNaturwissenschaften}{HTML}{70706F}
\definecolor{TUCMathematik}{HTML}{A10B70}
\definecolor{TUCMaschinenbau}{HTML}{123375}
\definecolor{TUCETIT}{HTML}{E4032D}
\definecolor{TUCInformatik}{HTML}{4A8246}
\definecolor{TUCWirtschaft}{HTML}{9D0736}
\definecolor{TUCPhilosophie}{HTML}{C65306}
\definecolor{TUCHSW}{HTML}{0075BF}
\definecolor{TUCGold}{HTML}{8D6831}
\definecolor{TUCSilber}{HTML}{9D9C9C}

\tl_new:N \g__tuc_faculty_color_tl
\tl_new:N \g__tuc_logo_file_tl
\tl_new:N \g__tuc_unit_tl
\tl_new:N \g__tuc_url_tl
\dim_new:N \g__tuc_logo_width_dim
\dim_new:N \g__tuc_header_height_dim
\dim_new:N \g__tuc_title_header_height_dim
\dim_new:N \g__tuc_footer_height_dim
\dim_new:N \g__tuc_hmargin_dim
\tl_gset:Nn \g__tuc_faculty_color_tl { TUCHaus }
\colorlet{TUCFaculty}{TUCHaus}
\cs_new_protected:Npn \__tuc_set_faculty_color:n #1
  {
    \tl_gset:Nn \g__tuc_faculty_color_tl {#1}
    \colorlet{TUCFaculty}{#1}
  }
\tl_gset:Nn \g__tuc_unit_tl { Technische~Universität~Chemnitz }
\tl_gset:Nn \g__tuc_url_tl { www.tu-chemnitz.de }
\dim_gset:Nn \g__tuc_logo_width_dim { 30mm }
\dim_gset:Nn \g__tuc_header_height_dim { 11mm }
\dim_gset:Nn \g__tuc_title_header_height_dim { 26mm }
\dim_gset:Nn \g__tuc_footer_height_dim { 6mm }
\dim_gset:Nn \g__tuc_hmargin_dim { 7mm }

\keys_define:nn { tuc / talk }
  {
    faculty .choice:,
    faculty / haus .code:n = \__tuc_set_faculty_color:n { TUCHaus },
    faculty / naturwissenschaften .code:n = \__tuc_set_faculty_color:n { TUCNaturwissenschaften },
    faculty / mathematik .code:n = \__tuc_set_faculty_color:n { TUCMathematik },
    faculty / maschinenbau .code:n = \__tuc_set_faculty_color:n { TUCMaschinenbau },
    faculty / etit .code:n = \__tuc_set_faculty_color:n { TUCETIT },
    faculty / informatik .code:n = \__tuc_set_faculty_color:n { TUCInformatik },
    faculty / wirtschaft .code:n = \__tuc_set_faculty_color:n { TUCWirtschaft },
    faculty / philosophie .code:n = \__tuc_set_faculty_color:n { TUCPhilosophie },
    faculty / hsw .code:n = \__tuc_set_faculty_color:n { TUCHSW },
    color .code:n = \__tuc_set_faculty_color:n {#1},
    logo .tl_gset:N = \g__tuc_logo_file_tl,
    unit .tl_gset:N = \g__tuc_unit_tl,
    url .tl_gset:N = \g__tuc_url_tl,
    logo-width .dim_gset:N = \g__tuc_logo_width_dim,
    header-height .dim_gset:N = \g__tuc_header_height_dim,
    title-header-height .dim_gset:N = \g__tuc_title_header_height_dim,
    footer-height .dim_gset:N = \g__tuc_footer_height_dim,
    hmargin .dim_gset:N = \g__tuc_hmargin_dim,
  }
\ProcessKeysOptions { tuc / talk }
\NewDocumentCommand \tucsetup { m } { \keys_set:nn { tuc / talk } {#1} }
\NewDocumentCommand \tucsetlogo { m } { \tl_gset:Nn \g__tuc_logo_file_tl {#1} }
\NewDocumentCommand \tucfaculty { m } { \keys_set:nn { tuc / talk } { faculty = #1 } }
\cs_new_protected:Npn \__tuc_logo:n #1
  { \tl_if_blank:VTF \g__tuc_logo_file_tl { \rule{#1}{0pt} } { \includegraphics[width=#1,keepaspectratio]{\g__tuc_logo_file_tl} } }

% L3 template types used internally by this theme.
\DeclareObjectType { tuc / area } { 0 }
\DeclareTemplateInterface { tuc / area } { header } { 0 }
  { height : length = 11mm, background : tokenlist = TUCHaus, foreground : tokenlist = white }
\DeclareTemplateInterface { tuc / area } { footer } { 0 }
  { height : length = 6mm, background : tokenlist = white, foreground : tokenlist = black }
\dim_new:N \l__tuc_area_height_dim
\tl_new:N \l__tuc_area_bg_tl
\tl_new:N \l__tuc_area_fg_tl
\DeclareTemplateCode { tuc / area } { header } { 0 }
  { height = \l__tuc_area_height_dim, background = \l__tuc_area_bg_tl, foreground = \l__tuc_area_fg_tl }
  {
    \noindent\rlap{|\textcolor{\l__tuc_area_bg_tl}{\rule{\paperwidth}{\l__tuc_area_height_dim}}}%
    \hspace*{\g__tuc_hmargin_dim}%
    \raisebox{.22\l__tuc_area_height_dim}{\__tuc_logo:n{\g__tuc_logo_width_dim}}%
    \hspace*{\g__tuc_hmargin_dim}%
    \raisebox{.35\l__tuc_area_height_dim}{\textcolor{\l__tuc_area_fg_tl}{\sffamily\bfseries\small\g__tuc_unit_tl}}%
  }
\DeclareTemplateCode { tuc / area } { footer } { 0 }
  { height = \l__tuc_area_height_dim, background = \l__tuc_area_bg_tl, foreground = \l__tuc_area_fg_tl }
  {
    \noindent\rlap{\textcolor{\l__tuc_area_bg_tl}{\rule{\paperwidth}{\l__tuc_area_height_dim}}}%
    \hspace*{\g__tuc_hmargin_dim}%
    \raisebox{.2\l__tuc_area_height_dim}{\textcolor{\l__tuc_area_fg_tl}{\sffamily\tiny\g__tuc_url_tl\hfill\thepage}}%
  }
\DeclareInstance { tuc / area } { tuc-header } { header } { height = \g__tuc_header_height_dim, background = TUCFaculty, foreground = white }
\DeclareInstance { tuc / area } { tuc-footer } { footer } { height = \g__tuc_footer_height_dim, background = white, foreground = black }

\makeatletter
\cs_new_protected:Npn \tuc_page_style:
  {
    \cs_set_nopar:Npn \ps@tuc
      {
        \cs_set_nopar:Npn \@oddhead { \UseInstance { tuc / area } { tuc-header } }
        \cs_set_nopar:Npn \@oddfoot { \UseInstance { tuc / area } { tuc-footer } }
        \cs_set_eq:NN \@evenhead \@oddhead
        \cs_set_eq:NN \@evenfoot \@oddfoot
      }
    \pagestyle{tuc}
  }
\makeatother
\AddToHook { begindocument } { \tuc_page_style: }

\NewDocumentCommand \tuctitleframe { }
  {
    \begin{frame}
      \thispagestyle{empty}
      \noindent\rlap{\textcolor{TUCFaculty}{\rule{\paperwidth}{\g__tuc_title_header_height_dim}}}%
      \hspace*{\g__tuc_hmargin_dim}%
      \raisebox{.38\g__tuc_title_header_height_dim}{\__tuc_logo:n{\g__tuc_logo_width_dim}}%
      \hspace*{\g__tuc_hmargin_dim}%
      \raisebox{.43\g__tuc_title_header_height_dim}{\textcolor{white}{\sffamily\bfseries\Large\@title}}%
      \par\vspace{10mm}
      {\sffamily\Large\@title\par}
      \vspace{2mm}
      {\sffamily\large\@subtitle\par}
      \vfill
      {\sffamily\@author\quad\@date\hfill\g__tuc_url_tl\par}
    \end{frame}
  }

