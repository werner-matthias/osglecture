      },
    padding    = \l__ltxtalk_slot_padding_dim,
    rule-color = \l__ltxtalk_slot_rule_tl,
    rule-thick = \l__ltxtalk_slot_rule_thick_dim,
    rotate = \l__ltxtalk_slot_rotate_tl,
