\DeclareTemplateCode { lttheme-slot } { standard } { 1 }
  {
    font       = \l__ltxtalk_slot_font_tl,
    color      = \l__ltxtalk_slot_color_tl,
    background = \l__ltxtalk_slot_bg_tl,
